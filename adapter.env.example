# LLM configuration for the Hermes AG-UI adapter.
# Copy to `adapter.env` (gitignored) and fill in your key.
#
# --- Option A: any OpenAI-compatible endpoint (OpenAI, OpenRouter, Together,
#     a local vLLM, etc.). Simplest — bypasses the `hermes` config entirely. ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
HERMES_AGUI_MODEL=gpt-4o

# --- Option B: use your existing `hermes setup` provider/model instead ---
# Leave OPENAI_BASE_URL unset and run `hermes setup` first; the adapter will
# resolve the provider, model, and credentials from your hermes config.

# Optional overrides:
# HERMES_AGUI_PROVIDER=openai
# HERMES_AGUI_TOOLSETS=hermes-acp
# PORT=8000
